        <di:waypoint x="1805" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f15_di" bpmnElement="f15">
        <di:waypoint x="1805" y="360" />
        <di:waypoint x="1805" y="390" />
        <di:waypoint x="1045" y="390" />
        <di:waypoint x="1045" y="345" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f16_di" bpmnElement="f16">
        <di:waypoint x="2245" y="320" />
        <di:waypoint x="2357" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="NoteRouting_di" bpmnElement="NoteRouting">
        <dc:Bounds x="160" y="440" width="1600" height="100" />
