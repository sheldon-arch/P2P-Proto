        <dc:Bounds x="190" y="560" width="2510" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_finmaker_di" bpmnElement="L_finmaker" isHorizontal="true">
        <dc:Bounds x="190" y="720" width="2510" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="267" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="257" y="182" width="56" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
