<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_UnifiedP2POverview" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_UnifiedP2POverview">
    <bpmn:participant id="Participant_UnifiedP2POverview" name="Unified Procure-to-Pay / Source-to-Pay - End-to-End Overview" processRef="Process_UnifiedP2POverview" />
  </bpmn:collaboration>
  <bpmn:process id="Process_UnifiedP2POverview" isExecutable="false">
    <bpmn:laneSet id="LaneSet_UnifiedP2POverview">
      <bpmn:lane id="L_admin" name="Administrator">
        <bpmn:flowNodeRef>AdminStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Seed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_req" name="Requester">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Requisition</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Revise</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_budget" name="Budget Owner">
        <bpmn:flowNodeRef>BudgetCheck</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_appr" name="Approver">
        <bpmn:flowNodeRef>Approve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwApproved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_buyer" name="Procurement / Buyer">
        <bpmn:flowNodeRef>Source</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PO</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_supplier" name="Supplier / Vendor">
        <bpmn:flowNodeRef>Onboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Ack</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Ship</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_recv" name="Receiving / Warehouse">
        <bpmn:flowNodeRef>Receive</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_qc" name="Quality">
        <bpmn:flowNodeRef>QcGate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Ncr</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_finmaker" name="Finance - Maker">
        <bpmn:flowNodeRef>Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Pay</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_finchecker" name="Finance - Checker">
        <bpmn:flowNodeRef>Check</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_mgmt" name="Management">
        <bpmn:flowNodeRef>MgmtApprove</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_sys" name="Platform / System">
        <bpmn:flowNodeRef>Route</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="AdminStart" name="Setup begins">
      <bpmn:documentation>Administrator setup precedes any transaction. [SCOR OE | source: blueprint]</bpmn:documentation>
      <bpmn:outgoing>fa</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Seed" name="Configure masters, roles, approval chain, budgets, tax">
      <bpmn:documentation>Admin pre-seeds before any transaction: master data (items, suppliers, UoM, currencies, warehouses, payment terms, projects/cost-centers, categories/segments, tax codes), users + roles + designations + business units (RBAC), the configurable approval chain + routing rules, budgets per cost-center x period, and the dynamic field config. Without routing rules and budgets, downstream routing and commitment fail. [SCOR OE2/OE4/OE5/OE11 | source: blueprint+RA build-new]</bpmn:documentation>
      <bpmn:incoming>fa</bpmn:incoming>
      <bpmn:outgoing>f0</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="Start" name="Need identified">
      <bpmn:documentation>A requester in any department identifies a purchase need (material, spare, service, or product-design item). Trigger for the cycle. [SCOR S1.1 Define Business Need | source: AB+RA]</bpmn:documentation>
      <bpmn:incoming>f0</bpmn:incoming>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Requisition" name="Raise requisition (lines, budget soft-check)">
      <bpmn:documentation>Requester creates a requisition: header (auto identifier, date, requester+department auto, category {Items|Spares|Services|ProductDesign}, direct/indirect, purchase type {Local|Import}, priority {ASAP|SameDay|Within2Days|Within1Week}, currency, project/cost-center) and one or more lines (item [search master or free-text -&gt; auto-create], quantity &gt;0, UoM, unit price, need date, product-used-for, available stock, line note, attachments). On submit, a soft budget check warns if over available; auto identifier generated; sees only own/department requisitions. [SCOR S1.1/O2 | ISO 7.5 | source: AB fields + RA structure]</bpmn:documentation>
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="BudgetCheck" name="Within budget or override?">
      <bpmn:documentation>Soft budget gate. If requisition value &lt;= cost-center available budget -&gt; proceeds. If over -&gt; Budget Owner must approve an override (logged) or the requisition is revised. Hard commit happens later at PO issue. [SCOR OE11 | source: build-new finance control]</bpmn:documentation>
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f3b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Route" name="Route into configurable approval chain">
      <bpmn:documentation>System resolves the approval chain by department/category/value, creates one completion per stage (NOT_STARTED), assigns the first stage (Requester pinned), least-loaded approver selected. [SCOR OE2 | ISO 8.4 | source: RA engine]</bpmn:documentation>
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Approve" name="Approve through stages (auto or manual)">
      <bpmn:documentation>Each stage: within auto-approval threshold -&gt; system auto-approves (nearest-bucket approver, logged); else the requested approver (or qualified assignee, never own requisition) approves or returns for revision. SoD enforced. [SCOR OE2 | source: RA auto-approval + AB FM/head as config]</bpmn:documentation>
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GwApproved" name="Approved?">
      <bpmn:documentation>Approved -&gt; sourcing. Rejected -&gt; return-for-revision loop to the requester with mandatory note. [source: both]</bpmn:documentation>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Revise" name="Revise and resubmit">
      <bpmn:documentation>Requester edits the same requisition per the rejection note (identifier unchanged) and resubmits. [source: both]</bpmn:documentation>
      <bpmn:incoming>f3b</bpmn:incoming>
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Source" name="Source: RFQ, compare landed cost, select, award">
      <bpmn:documentation>Buyer sources: prequalify/discover suppliers, float RFQ to &gt;=3 (email+OTP form), capture structured quotes (price, payment terms, delivery terms, incoterm, charges), negotiate, compare on normalized landed cost + scorecard, select (justify non-top pick), award + capture contract terms. Repeat/preferred buys bypass via framework call-off. [SCOR S1.2-S1.10 | source: AB depth + RA mechanics]</bpmn:documentation>
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Onboard" name="Onboard / qualify supplier (if new)">
      <bpmn:documentation>A new supplier completes onboarding (profile, addresses, tax, qualification docs: certs/COA/AVL, risk/security/ESG attributes) and is approved before any order. Gates ordering. [SCOR S1.6 | ISO 8.4.1 + family | source: RA lifecycle + AB qualification]</bpmn:documentation>
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="PO" name="Issue PO (budget commit, terms, PDF)">
      <bpmn:documentation>Buyer issues the PO from requisition+quote: budget HARD-committed (encumbrance), incoterms/scope/currency+exchange rate, T&amp;Cs, delivery place/date, tax on lines, ISO doc ref; emitted as PDF to the supplier. Editable until first receipt (qty tolerance). Buyer cannot approve own PO (SoD). [SCOR S2.1 | ISO 8.4.3 | source: AB + commit build-new]</bpmn:documentation>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Ack" name="Acknowledge PO">
      <bpmn:documentation>Supplier acknowledges the PO before production; any advance payment triggers here per the schedule. [SCOR S2.1 | source: both]</bpmn:documentation>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Ship" name="Manufacture, ship, share documents">
      <bpmn:documentation>Supplier manufactures and ships; shares documents after dispatch (invoice, packing list, certificate of origin, AWB/BL, and for import: Bayan after arrival, health cert for food, DG declaration). [SCOR S2.2/S2.3 | source: AB import docs]</bpmn:documentation>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Receive" name="Receive, inspect (GRN), QC gate">
      <bpmn:documentation>Receiving records delivery (partial-delivery blocks; transport-mode + customs tracking for import). Materials -&gt; COA+sample to QC -&gt; QC approves (hard block if no COA) -&gt; GRN raised, GR/IR accrued; qty tolerance +/-5-10% amends PO first. Spares/services -&gt; Engineering receives, closes requisition (no GRN). [SCOR S2.4/S2.5/S2.6 | ISO 8.6/8.7 | source: AB QC + RA blocks]</bpmn:documentation>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="QcGate" name="QC pass?">
      <bpmn:documentation>Pass -&gt; GRN + onward. Fail -&gt; non-conformance (NCR) raised, disposition (return/rework/concession/scrap), may start RMA + CAPA loop feeding supplier re-evaluation. [SCOR S2.5 | ISO 8.7/10.2 | source: AB NCR + build-new CAPA]</bpmn:documentation>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Ncr" name="Raise NCR -&gt; RMA / CAPA loop">
      <bpmn:documentation>NCR (item, delivery-note no., date, % non-conformance, image) by QC/FM/requester -&gt; handler resolves with supplier -&gt; return (S4) and/or corrective action -&gt; effectiveness review -&gt; feeds supplier scorecard + may SUSPEND supplier. [SCOR S4 | ISO 8.6-&gt;8.7-&gt;10.2-&gt;8.4.1 | source: build-new]</bpmn:documentation>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Invoice" name="Capture invoice, two/three-way match">
      <bpmn:documentation>Invoice captured (with documents). Match: three-way (PO+GRN+invoice) for materials, two-way (PO+invoice) for services/no-GRN; within price/qty tolerance + tax-inclusive -&gt; auto-clear and relieve GR/IR; else exception (price/qty/missing-GR/duplicate-invoice/tax-mismatch) routed to resolver -&gt; accept/adjust/credit-note/debit-note/reject. [SCOR S2.7 | ISO 8.6 | source: build-new + AB package]</bpmn:documentation>
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Pay" name="Schedule and process payment (installments)">
      <bpmn:documentation>Finance-Maker builds the payment schedule per terms {100% advance | part-advance+against-docs | part-advance+against-shipment | 30/70 | net 30/60/90}; approves installments full or partial (+remainder), processes with receipt, handles advance recoupment + retention, cash float for cash buys, withholding tax. Overdue reminder ~28d. [SCOR S2.7 | source: RA installments + AB terms]</bpmn:documentation>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Check" name="Approve payment release (checker)">
      <bpmn:documentation>Finance-Checker (Chief Accountant) reviews and approves the prepared payment before release; maker != checker (financial-control SoD per SOX/COSO + ISO 37001, NOT ISO 9001). Reschedule with reason if held. [source: both, segregation]</bpmn:documentation>
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Complete" name="Close out, update analytics + audit">
      <bpmn:documentation>Cycle closes when stage = POST_DELIVERY, all approvals APPROVED, all matches cleared, payments settled, no open NCR/CAPA block. Commitment relieved to actual; supplier scorecard (OTIF/perfect-order, quality, cost, responsiveness), cycle-time, savings, spend analytics updated; audit log + SSE emitted throughout. [SCOR OE3 + RL/RS/CO | ISO 8.4.1 | source: both + KPIs]</bpmn:documentation>
      <bpmn:incoming>f20b</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Source-to-pay complete">
      <bpmn:documentation>Fully recorded, benchmark-traceable cycle. [source: build-new]</bpmn:documentation>
      <bpmn:incoming>f21</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="MgmtApprove" name="Management final approval (terminal vertical)">
      <bpmn:documentation>Management is the terminal vertical in the approval chain; it gives final sign-off, frequently exercised through approving the final payment installment release. Marks the Management completion APPROVED, the last gate before the COMPLETED guard. [SCOR OE1 (Supply Chain Strategy) / S2.7 | source: RA MANAGEMENT vertical]</bpmn:documentation>
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f20b</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="fa" sourceRef="AdminStart" targetRef="Seed" />
    <bpmn:sequenceFlow id="f0" name="config ready" sourceRef="Seed" targetRef="Start" />
    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="Requisition" />
    <bpmn:sequenceFlow id="f2" sourceRef="Requisition" targetRef="BudgetCheck" />
    <bpmn:sequenceFlow id="f3" name="within budget / override approved" sourceRef="BudgetCheck" targetRef="Route" />
    <bpmn:sequenceFlow id="f3b" name="over budget, no override" sourceRef="BudgetCheck" targetRef="Revise" />
    <bpmn:sequenceFlow id="f4" sourceRef="Route" targetRef="Approve" />
    <bpmn:sequenceFlow id="f5" sourceRef="Approve" targetRef="GwApproved" />
    <bpmn:sequenceFlow id="f6" name="Approved" sourceRef="GwApproved" targetRef="Source" />
    <bpmn:sequenceFlow id="f7" name="Rejected" sourceRef="GwApproved" targetRef="Revise" />
    <bpmn:sequenceFlow id="f8" sourceRef="Revise" targetRef="Approve" />
    <bpmn:sequenceFlow id="f9" sourceRef="Source" targetRef="Onboard" />
    <bpmn:sequenceFlow id="f10" sourceRef="Onboard" targetRef="PO" />
    <bpmn:sequenceFlow id="f11" sourceRef="PO" targetRef="Ack" />
    <bpmn:sequenceFlow id="f12" sourceRef="Ack" targetRef="Ship" />
    <bpmn:sequenceFlow id="f13" sourceRef="Ship" targetRef="Receive" />
    <bpmn:sequenceFlow id="f14" sourceRef="Receive" targetRef="QcGate" />
    <bpmn:sequenceFlow id="f15" name="QC pass" sourceRef="QcGate" targetRef="Invoice" />
    <bpmn:sequenceFlow id="f16" name="QC fail" sourceRef="QcGate" targetRef="Ncr" />
    <bpmn:sequenceFlow id="f17" name="resolved / accepted" sourceRef="Ncr" targetRef="Invoice" />
    <bpmn:sequenceFlow id="f18" sourceRef="Invoice" targetRef="Pay" />
    <bpmn:sequenceFlow id="f19" sourceRef="Pay" targetRef="Check" />
    <bpmn:sequenceFlow id="f20" sourceRef="Check" targetRef="MgmtApprove" />
    <bpmn:sequenceFlow id="f21" sourceRef="Complete" targetRef="End" />
    <bpmn:sequenceFlow id="f20b" sourceRef="MgmtApprove" targetRef="Complete" />
    <bpmn:textAnnotation id="NoteOverview">
      <bpmn:text>End-to-end source-to-pay overview. Lanes are roles; Platform/System is automated. Happy path left-to-right; loops (over-budget, rejected) return to revise. Each labelled area expands into a per-domain diagram (02-12) and the edge cases (e01-e12). Foundation services (configurable approval engine, field engine, FX, audit, notifications, SSE, bulk import, document storage, analytics, RBAC, budget/commitment, tax) underlie every step. SCOR-named spine; benchmark-traceable.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_UnifiedP2POverview_1" sourceRef="Complete" targetRef="NoteOverview" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_UnifiedP2POverview">
    <bpmndi:BPMNPlane id="Plane_UnifiedP2POverview" bpmnElement="Collaboration_UnifiedP2POverview">
      <bpmndi:BPMNShape id="Participant_UnifiedP2POverview_di" bpmnElement="Participant_UnifiedP2POverview" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="4250" height="1920" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_admin_di" bpmnElement="L_admin" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_req_di" bpmnElement="L_req" isHorizontal="true">
        <dc:Bounds x="190" y="240" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_budget_di" bpmnElement="L_budget" isHorizontal="true">
        <dc:Bounds x="190" y="400" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_appr_di" bpmnElement="L_appr" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_buyer_di" bpmnElement="L_buyer" isHorizontal="true">
        <dc:Bounds x="190" y="720" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_supplier_di" bpmnElement="L_supplier" isHorizontal="true">
        <dc:Bounds x="190" y="880" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_recv_di" bpmnElement="L_recv" isHorizontal="true">
        <dc:Bounds x="190" y="1040" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_qc_di" bpmnElement="L_qc" isHorizontal="true">
        <dc:Bounds x="190" y="1200" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_finmaker_di" bpmnElement="L_finmaker" isHorizontal="true">
        <dc:Bounds x="190" y="1360" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_finchecker_di" bpmnElement="L_finchecker" isHorizontal="true">
        <dc:Bounds x="190" y="1520" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_mgmt_di" bpmnElement="L_mgmt" isHorizontal="true">
        <dc:Bounds x="190" y="1680" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_sys_di" bpmnElement="L_sys" isHorizontal="true">
        <dc:Bounds x="190" y="1840" width="4220" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdminStart_di" bpmnElement="AdminStart">
        <dc:Bounds x="267" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="257" y="182" width="56" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Seed_di" bpmnElement="Seed">
        <dc:Bounds x="415" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="647" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="637" y="342" width="56" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Requisition_di" bpmnElement="Requisition">
        <dc:Bounds x="795" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BudgetCheck_di" bpmnElement="BudgetCheck" isMarkerVisible="true">
        <dc:Bounds x="830" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="820" y="509" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Route_di" bpmnElement="Route">
        <dc:Bounds x="985" y="1880" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Approve_di" bpmnElement="Approve">
        <dc:Bounds x="1175" y="600" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwApproved_di" bpmnElement="GwApproved" isMarkerVisible="true">
        <dc:Bounds x="1400" y="615" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1390" y="669" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Revise_di" bpmnElement="Revise">
        <dc:Bounds x="1555" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Source_di" bpmnElement="Source">
