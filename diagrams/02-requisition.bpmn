        <dc:Bounds x="605" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="NewItem_di" bpmnElement="NewItem">
        <dc:Bounds x="795" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ApproveItem_di" bpmnElement="ApproveItem">
        <dc:Bounds x="985" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LinkItem_di" bpmnElement="LinkItem">
        <dc:Bounds x="1175" y="600" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwSaveOrSubmit_di" bpmnElement="GwSaveOrSubmit" isMarkerVisible="true">
        <dc:Bounds x="1400" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1390" y="189" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Draft_di" bpmnElement="Draft">
        <dc:Bounds x="1555" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Submit_di" bpmnElement="Submit">
        <dc:Bounds x="1745" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
