        <di:waypoint x="1710" y="160" />
        <di:waypoint x="1710" y="640" />
        <di:waypoint x="1745" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11">
        <di:waypoint x="1745" y="640" />
        <di:waypoint x="1598" y="640" />
        <di:waypoint x="1598" y="320" />
        <di:waypoint x="1450" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12">
        <di:waypoint x="1450" y="320" />
