      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <di:waypoint x="1105" y="800" />
        <di:waypoint x="1210" y="800" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <di:waypoint x="1260" y="800" />
        <di:waypoint x="1935" y="800" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <di:waypoint x="1260" y="800" />
        <di:waypoint x="1400" y="800" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11">
        <di:waypoint x="1450" y="800" />
        <di:waypoint x="1503" y="800" />
        <di:waypoint x="1503" y="320" />
        <di:waypoint x="1555" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12">
