      <bpmndi:BPMNShape id="SupplyDue_di" bpmnElement="SupplyDue" isMarkerVisible="true">
        <dc:Bounds x="640" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="630" y="189" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="FloatLoad_di" bpmnElement="FloatLoad">
