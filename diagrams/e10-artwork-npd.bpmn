<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_E10ArtworkNpd" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_E10ArtworkNpd">
    <bpmn:participant id="Participant_E10ArtworkNpd" name="e10 - Artwork and New-Product-Development Approval" processRef="Process_E10ArtworkNpd" />
  </bpmn:collaboration>
  <bpmn:process id="Process_E10ArtworkNpd" isExecutable="false">
    <bpmn:laneSet id="LaneSet_E10ArtworkNpd">
      <bpmn:lane id="L_req" name="Requester">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwNpd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwPrinted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_buyer" name="Procurement / Buyer">
        <bpmn:flowNodeRef>RequestSamples</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwReorder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwArtworkOrigin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ForwardToPrint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Corrections</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_supplier" name="Supplier / Vendor">
        <bpmn:flowNodeRef>SupplierSamples</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubmitProof</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_appr" name="Approver">
        <bpmn:flowNodeRef>ReviewSamples</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwSampleOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewFactoryMkt</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_qc" name="Quality">
        <bpmn:flowNodeRef>ReviewQuality</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_lang" name="Reviewer (Language)">
        <bpmn:flowNodeRef>ReviewLanguage</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_sys" name="Platform / System">
        <bpmn:flowNodeRef>ForkReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>JoinReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GwAllApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Print</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="New product / printed item need">
      <bpmn:documentation>Trigger: a need for a new product (NPD) and/or a printed packaging item (label, carton, sleeve). Two intertwined loops follow: the NPD sample loop (raw-material + artwork samples) and the artwork-proof approval loop. [SCOR S1.1/PLM | source: AB NPD + artwork]</bpmn:documentation>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GwNpd" name="New product development needed?">
      <bpmn:documentation>Expression: isNewProduct == true (a product not previously made). True -&gt; run the NPD sample loop first (RM + artwork samples reviewed by factory + marketing). False -&gt; go straight to the artwork decision for an existing product. [SCOR S1.1 | source: AB NPD]</bpmn:documentation>
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="RequestSamples" name="Factory requests RM + artwork samples">
      <bpmn:documentation>Buyer/factory requests raw-material samples and first-cut artwork samples from the supplier for the new product. Captures sampleType {RM|artwork}, quantity, target spec. [SCOR S1.6/PLM | source: AB NPD sample request]</bpmn:documentation>
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="SupplierSamples" name="Supplier sends samples">
      <bpmn:documentation>Supplier sends the RM + artwork samples for evaluation. [SCOR S1.6 | source: AB]</bpmn:documentation>
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="ReviewSamples" name="Factory + marketing review samples">
      <bpmn:documentation>Factory (fit/function/material) + marketing (look/positioning) review the samples. Decision dropdown {approve-into-flow | rework}. [SCOR S1.6/PLM | source: AB NPD review]</bpmn:documentation>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GwSampleOk" name="Samples approved?">
      <bpmn:documentation>Expression: sampleDecision == approve. True -&gt; the new product enters the normal flow and proceeds to the artwork decision. False -&gt; rework: loop back to request revised samples from the supplier. [SCOR S1.6 | source: AB sample loop]</bpmn:documentation>
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GwPrinted" name="Item is printed?">
      <bpmn:documentation>Expression: item.isPrinted == true (label/carton/sleeve carrying artwork). True -&gt; artwork approval path. False (unprinted item) -&gt; no artwork needed, exit to normal procurement. [SCOR S1.1 | source: AB printed-item]</bpmn:documentation>
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GwReorder" name="Reorder of last-approved artwork?">
      <bpmn:documentation>Expression: item.lastApprovedArtworkId != null AND noArtworkChange == true. True -&gt; SHORTCUT: reuse the last-approved artwork, skip the proof + review loop, print directly (reorder). False -&gt; new or changed artwork needs proofing. [SCOR S1.10 | source: AB last-approved-artwork reorder shortcut]</bpmn:documentation>
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GwArtworkOrigin" name="Customer-supplied or own-brand artwork?">
      <bpmn:documentation>Expression: artworkOrigin == customer-supplied. customer-supplied -&gt; the customer's print-ready artwork is forwarded to the supplier to print DIRECTLY (no internal proof review; the customer owns it). own-brand -&gt; the supplier submits a proof for internal parallel review. [SCOR S1.10 | source: AB customer vs own-brand artwork]</bpmn:documentation>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="ForwardToPrint" name="Forward customer artwork to supplier to print">
      <bpmn:documentation>Customer-supplied print-ready artwork is sent to the supplier to print directly. No internal proof loop. [SCOR S1.10 | source: AB customer artwork direct]</bpmn:documentation>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="SubmitProof" name="Supplier submits proof (1-up / 2-up / 10-up)">
      <bpmn:documentation>For own-brand artwork the supplier submits a proof at the agreed imposition: 1-up (single), 2-up, or 10-up (multiple repeats per sheet, dropdown {1-up|2-up|10-up}). The proof enters the parallel internal review. [SCOR S1.10 | source: AB proof 1-up/2-up/10-up]</bpmn:documentation>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:incoming>f26</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:parallelGateway id="ForkReview" name="Parallel proof review">
      <bpmn:documentation>Parallel split: the proof is reviewed simultaneously by (A) factory + marketing [marketing engaged ONLY if the product is new], (B) quality [English text + structural correctness], and (C) the language reviewer [Arabic text]. All three branches must complete and approve before print. [SCOR S1.10/PLM | source: AB parallel artwork review]</bpmn:documentation>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:outgoing>f18</bpmn:outgoing>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="ReviewFactoryMkt" name="Factory + marketing review">
      <bpmn:documentation>Branch A. Factory checks dieline/fit; marketing checks branding/positioning. Expression for marketing engagement: isNewProduct == true -&gt; marketing reviews; else factory only. Decision {approve | corrections}. [SCOR S1.10 | source: AB factory+marketing, marketing only if new]</bpmn:documentation>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="ReviewQuality" name="Quality review (English + structure)">
      <bpmn:documentation>Branch B. Quality verifies English text accuracy, mandatory declarations, barcodes, dimensions, and structural correctness of the artwork. Decision {approve | corrections}. [SCOR S1.10 | ISO 8.6 | source: AB quality artwork review]</bpmn:documentation>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="ReviewLanguage" name="Language reviewer (Arabic text)">
      <bpmn:documentation>Branch C. The language reviewer verifies the Arabic text (translation accuracy, script, right-to-left layout). Decision {approve | corrections}. A separate specialist lane because Arabic correctness is a distinct competency. [SCOR S1.10 | source: AB Arabic language reviewer]</bpmn:documentation>
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="JoinReview" name="Join: all reviews returned">
      <bpmn:documentation>Parallel join: waits for all engaged branches (A, B, C) to return. Then evaluate whether ALL approved. [SCOR S1.10 | source: AB parallel join]</bpmn:documentation>
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="GwAllApproved" name="All reviewers approved?">
      <bpmn:documentation>Expression: reviewA == approve AND reviewB == approve AND reviewC == approve. True -&gt; release to print. False -&gt; any branch raised corrections; collate corrections and loop back to the supplier for a revised proof. [SCOR S1.10 | source: AB all-approved gate]</bpmn:documentation>
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f24</bpmn:outgoing>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Corrections" name="Collate corrections; request revised proof">
      <bpmn:documentation>Buyer collates the corrections from every reviewer into one markup and requests a revised proof from the supplier. The revised proof re-enters the parallel review (revised-proof loop). [SCOR S1.10 | source: AB revised-proof loop]</bpmn:documentation>
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Print" name="Release to print; store last-approved artwork">
      <bpmn:documentation>System releases the approved artwork to print and stores it as item.lastApprovedArtworkId (with version + approval record) so a future reorder can take the last-approved-artwork shortcut. Audit + SSE. The item then proceeds into the normal procurement/PO flow. [SCOR S1.10/OE4 | source: AB print release + last-approved store]</bpmn:documentation>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Artwork approved / printed; into normal flow">
      <bpmn:documentation>NPD samples approved (if applicable) and artwork approved/printed (customer-direct, reorder shortcut, or full parallel review). The item joins the normal sourcing/PO cycle. [SCOR S1.10 | source: AB]</bpmn:documentation>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:incoming>f27</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start" targetRef="GwNpd" />
    <bpmn:sequenceFlow id="f2" name="new product" sourceRef="GwNpd" targetRef="RequestSamples" />
    <bpmn:sequenceFlow id="f3" name="existing product" sourceRef="GwNpd" targetRef="GwPrinted" />
    <bpmn:sequenceFlow id="f4" sourceRef="RequestSamples" targetRef="SupplierSamples" />
    <bpmn:sequenceFlow id="f5" sourceRef="SupplierSamples" targetRef="ReviewSamples" />
    <bpmn:sequenceFlow id="f6" sourceRef="ReviewSamples" targetRef="GwSampleOk" />
    <bpmn:sequenceFlow id="f7" name="approve into flow" sourceRef="GwSampleOk" targetRef="GwPrinted" />
    <bpmn:sequenceFlow id="f8" name="rework -&gt; revised samples" sourceRef="GwSampleOk" targetRef="RequestSamples" />
    <bpmn:sequenceFlow id="f9" name="printed item" sourceRef="GwPrinted" targetRef="GwReorder" />
    <bpmn:sequenceFlow id="f10" name="not printed -&gt; normal flow" sourceRef="GwPrinted" targetRef="End" />
    <bpmn:sequenceFlow id="f11" name="reorder: reuse last-approved artwork" sourceRef="GwReorder" targetRef="Print" />
    <bpmn:sequenceFlow id="f12" name="new/changed artwork" sourceRef="GwReorder" targetRef="GwArtworkOrigin" />
    <bpmn:sequenceFlow id="f13" name="customer-supplied" sourceRef="GwArtworkOrigin" targetRef="ForwardToPrint" />
    <bpmn:sequenceFlow id="f14" name="own-brand" sourceRef="GwArtworkOrigin" targetRef="SubmitProof" />
    <bpmn:sequenceFlow id="f15" sourceRef="ForwardToPrint" targetRef="Print" />
    <bpmn:sequenceFlow id="f16" sourceRef="SubmitProof" targetRef="ForkReview" />
    <bpmn:sequenceFlow id="f17" name="A: factory + marketing (mkt if new)" sourceRef="ForkReview" targetRef="ReviewFactoryMkt" />
    <bpmn:sequenceFlow id="f18" name="B: quality (English + structure)" sourceRef="ForkReview" targetRef="ReviewQuality" />
    <bpmn:sequenceFlow id="f19" name="C: language (Arabic)" sourceRef="ForkReview" targetRef="ReviewLanguage" />
    <bpmn:sequenceFlow id="f20" sourceRef="ReviewFactoryMkt" targetRef="JoinReview" />
    <bpmn:sequenceFlow id="f21" sourceRef="ReviewQuality" targetRef="JoinReview" />
    <bpmn:sequenceFlow id="f22" sourceRef="ReviewLanguage" targetRef="JoinReview" />
    <bpmn:sequenceFlow id="f23" sourceRef="JoinReview" targetRef="GwAllApproved" />
    <bpmn:sequenceFlow id="f24" name="all approved" sourceRef="GwAllApproved" targetRef="Print" />
    <bpmn:sequenceFlow id="f25" name="any corrections" sourceRef="GwAllApproved" targetRef="Corrections" />
    <bpmn:sequenceFlow id="f26" name="revised proof loop" sourceRef="Corrections" targetRef="SubmitProof" />
    <bpmn:sequenceFlow id="f27" sourceRef="Print" targetRef="End" />
    <bpmn:textAnnotation id="NoteArtwork">
      <bpmn:text>Two loops. NPD sample loop: factory requests RM + artwork samples, supplier sends, factory + marketing review, approve into flow or rework. Artwork: a reorder of unchanged artwork takes the last-approved-artwork shortcut and prints directly. Customer-supplied artwork is forwarded to the supplier to print directly. Own-brand artwork is submitted as a proof (1-up / 2-up / 10-up) and reviewed in PARALLEL by factory + marketing (marketing only if the product is new), quality (English + structure), and a language reviewer (Arabic). Only when all engaged reviewers approve does it print; any corrections collate into one revised-proof loop. Approved artwork is stored as last-approved for future reorders.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_E10ArtworkNpd_1" sourceRef="ForkReview" targetRef="NoteArtwork" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_E10ArtworkNpd">
    <bpmndi:BPMNPlane id="Plane_E10ArtworkNpd" bpmnElement="Collaboration_E10ArtworkNpd">
      <bpmndi:BPMNShape id="Participant_E10ArtworkNpd_di" bpmnElement="Participant_E10ArtworkNpd" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="3300" height="1120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_req_di" bpmnElement="L_req" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="3270" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_buyer_di" bpmnElement="L_buyer" isHorizontal="true">
        <dc:Bounds x="190" y="240" width="3270" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_supplier_di" bpmnElement="L_supplier" isHorizontal="true">
