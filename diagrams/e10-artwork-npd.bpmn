        <dc:Bounds x="450" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="189" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RequestSamples_di" bpmnElement="RequestSamples">
        <dc:Bounds x="605" y="280" width="120" height="80" />
