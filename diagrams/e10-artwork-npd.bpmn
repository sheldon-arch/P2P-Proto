        <dc:Bounds x="190" y="560" width="3270" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_qc_di" bpmnElement="L_qc" isHorizontal="true">
        <dc:Bounds x="190" y="720" width="3270" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_lang_di" bpmnElement="L_lang" isHorizontal="true">
        <dc:Bounds x="190" y="880" width="3270" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_sys_di" bpmnElement="L_sys" isHorizontal="true">
        <dc:Bounds x="190" y="1040" width="3270" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="267" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="257" y="182" width="56" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
