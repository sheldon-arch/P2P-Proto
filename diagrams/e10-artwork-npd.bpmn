        <dc:Bounds x="2160" y="1095" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2150" y="1149" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewFactoryMkt_di" bpmnElement="ReviewFactoryMkt">
        <dc:Bounds x="2315" y="600" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewQuality_di" bpmnElement="ReviewQuality">
        <dc:Bounds x="2315" y="760" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewLanguage_di" bpmnElement="ReviewLanguage">
        <dc:Bounds x="2315" y="920" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="JoinReview_di" bpmnElement="JoinReview" isMarkerVisible="true">
        <dc:Bounds x="2540" y="1095" width="50" height="50" />
