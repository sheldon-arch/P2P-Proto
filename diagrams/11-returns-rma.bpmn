        <dc:Bounds x="190" y="720" width="2510" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="L_sys_di" bpmnElement="L_sys" isHorizontal="true">
        <dc:Bounds x="190" y="880" width="2510" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="267" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="257" y="182" width="56" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Initiate_di" bpmnElement="Initiate">
        <dc:Bounds x="415" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Authorize_di" bpmnElement="Authorize">
        <dc:Bounds x="605" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GwAuth_di" bpmnElement="GwAuth" isMarkerVisible="true">
        <dc:Bounds x="830" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="820" y="349" width="70" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Declined_di" bpmnElement="Declined">
        <dc:Bounds x="985" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Identify_di" bpmnElement="Identify">
        <dc:Bounds x="1175" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Schedule_di" bpmnElement="Schedule">
        <dc:Bounds x="1365" y="600" width="120" height="80" />
      </bpmndi:BPMNShape>
