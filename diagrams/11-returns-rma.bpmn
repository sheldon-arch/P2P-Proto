        <di:waypoint x="1028" y="160" />
        <di:waypoint x="1175" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <di:waypoint x="880" y="320" />
        <di:waypoint x="985" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <di:waypoint x="1105" y="320" />
        <di:waypoint x="1826" y="320" />
        <di:waypoint x="1826" y="960" />
        <di:waypoint x="2547" y="960" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <di:waypoint x="1295" y="160" />
        <di:waypoint x="1330" y="160" />
        <di:waypoint x="1330" y="640" />
        <di:waypoint x="1365" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <di:waypoint x="1485" y="640" />
        <di:waypoint x="1520" y="640" />
        <di:waypoint x="1520" y="480" />
        <di:waypoint x="1555" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <di:waypoint x="1675" y="480" />
        <di:waypoint x="1728" y="480" />
        <di:waypoint x="1728" y="800" />
        <di:waypoint x="1780" y="800" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <di:waypoint x="1830" y="800" />
        <di:waypoint x="1935" y="800" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11">
        <di:waypoint x="1830" y="800" />
        <di:waypoint x="2125" y="800" />
